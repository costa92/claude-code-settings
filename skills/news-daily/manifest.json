{
  "name": "news-daily",
  "version": "2.2.0",
  "description": "AI news aggregator that fetches from 11 sources: English (smol.ai, TLDR, OpenAI, DeepMind, MIT Tech Review, TechCrunch, Import AI, Last Week in AI, Ahead of AI), Chinese (量子位), Community (Hacker News)",
  "repository": "geekjourneyx/ai-daily-skill",
  "requires": {
    "packages": [
      {
        "name": "feedparser",
        "optional": false,
        "purpose": "Parse RSS feeds from multiple sources",
        "install": "pip install feedparser"
      },
      {
        "name": "requests",
        "optional": false,
        "purpose": "HTTP client for fetching RSS",
        "install": "pip install requests"
      }
    ],
    "apis": [
      {
        "name": "smol.ai RSS",
        "optional": false,
        "purpose": "Daily AI news digest (default source)",
        "url": "https://news.smol.ai/rss.xml"
      },
      {
        "name": "TLDR Tech",
        "optional": true,
        "purpose": "Daily tech newsletter covering AI, startups, and dev news",
        "url": "https://tldr.tech/rss"
      },
      {
        "name": "OpenAI Blog",
        "optional": true,
        "purpose": "OpenAI official blog: model releases, research announcements",
        "url": "https://openai.com/blog/rss.xml"
      },
      {
        "name": "Google DeepMind Blog",
        "optional": true,
        "purpose": "Cutting-edge AI research from Google DeepMind",
        "url": "https://deepmind.google/blog/rss.xml"
      },
      {
        "name": "MIT Tech Review AI",
        "optional": true,
        "purpose": "MIT Technology Review AI coverage: deep analysis on AI trends",
        "url": "https://www.technologyreview.com/topic/artificial-intelligence/feed"
      },
      {
        "name": "TechCrunch AI",
        "optional": true,
        "purpose": "TechCrunch AI section: startups, funding, product launches",
        "url": "https://techcrunch.com/category/artificial-intelligence/feed/"
      },
      {
        "name": "Import AI",
        "optional": true,
        "purpose": "Jack Clark's weekly AI newsletter",
        "url": "https://importai.substack.com/feed"
      },
      {
        "name": "Last Week in AI",
        "optional": true,
        "purpose": "Weekly AI news summary",
        "url": "https://lastweekin.ai/feed"
      },
      {
        "name": "Ahead of AI",
        "optional": true,
        "purpose": "Sebastian Raschka's ML/AI research updates",
        "url": "https://magazine.sebastianraschka.com/feed"
      },
      {
        "name": "量子位 (QbitAI)",
        "optional": true,
        "purpose": "Chinese AI news media",
        "url": "https://www.qbitai.com/feed"
      },
      {
        "name": "Hacker News AI",
        "optional": true,
        "purpose": "AI discussions from Hacker News",
        "url": "https://hnrss.org/newest?q=AI+OR+LLM+OR+GPT+OR+Claude&points=30"
      }
    ]
  }
}
